# Aether deployment config schema (Sprint 10 Stage B). This file is the single
# documented schema — see docs/deployment.md for semantics and failure modes.
# Copy to .env / set as platform env vars. NEVER commit real values; every
# secret value is entered by the human directly into the platform dashboard.

# ---------------------------------------------------------------------------
# API (FastAPI container)
# ---------------------------------------------------------------------------

# 'development' (default) or 'production'. Production REQUIRES the variables
# marked [prod-required] below and fails loudly at startup without them.
AETHER_ENV=development

# [prod-required] Comma-separated EXACT CORS origins (scheme://host[:port],
# no wildcards, no trailing slash). Production value per the Gate A amendment:
# AETHER_ALLOWED_ORIGINS=https://aether.arkaneworks.co
AETHER_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# [prod-required] Git SHA of the deployed checkout. Baked as a Docker build
# arg (see Dockerfile) — never set by hand, never a runtime `git` call.
# AETHER_GIT_SHA=<baked at build>

# Optional: override the data root holding stage_a_outputs/, stage_b_outputs/,
# attribution_outputs/, eval/benchmark/ (defaults to the repo root; the Docker
# image sets it to the baked artifact tree).
# AETHER_DATA_ROOT=/app/data

# ---------------------------------------------------------------------------
# Web (Next.js — NEXT_PUBLIC_* values are PUBLIC by design: they are inlined
# into the client JS bundle at build time and visible to every visitor)
# ---------------------------------------------------------------------------

# Where the API lives. Local dev default; production points at the Fly app.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Optional Cesium ion token (client-visible by design; URL-restrict it in the
# ion dashboard if ever used). Per the Gate A ruling ion is NOT provisioned;
# token-free ESRI World Imagery is the default.
# NEXT_PUBLIC_CESIUM_ION_TOKEN=
