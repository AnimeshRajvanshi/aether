# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# Build/dist dirs are Python packaging artifacts — anchor to repo root so they
# don't shadow legitimate source dirs in the JS app (e.g. apps/web/src/lib).
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# uv
.uv/

