# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment / secrets — every .env variant is ignored (Sprint 10 F5: the old
# patterns missed non-.local names like .env.production); the committed schema
# template is the single exception.
.env
.env.*
!.env.example
*.pem

# Data / caches (we never check in raw scenes)
data/
cache/
.aether_cache/
*.tif
*.tiff
*.zarr
*.nc
*.h5
*.hdf

# Rendered outputs (PNG maps from reproduce command)
*_plume.png

# Sprint 2 derived rasters — npz files are large (~30 MB) and regenerable
# via scripts/run_stage_a_*.py. PNG / JSON / MD artefacts in the same
# directories are deliberately KEPT so the validation doc's visual evidence
# is visible on GitHub.
stage_a_outputs/**/*.npz
stage_b_outputs/**/*.npz
# Pre-LOOCV snapshot is a debugging backup, not for the repo.
stage_a_outputs/**/_pre_loocv/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# OS
Thumbs.db
